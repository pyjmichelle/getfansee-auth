# Auth E2E Environment Template (Sandbox only)
# Copy to .env.local and fill real values.

# ---- Supabase Sandbox ----
NEXT_PUBLIC_SUPABASE_URL=your_sandbox_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_sandbox_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_sandbox_service_role_key

# ---- App / Playwright ----
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
AUTH_E2E_REAL_OAUTH=1
NEXT_PUBLIC_TEST_MODE=false

# ---- Mailpit ----
MAILPIT_BASE_URL=http://127.0.0.1:8025
MAILPIT_INBOX_TIMEOUT_MS=60000
MAILPIT_POLL_INTERVAL_MS=2000

# ---- Google OAuth Test Account (required for full automation) ----
E2E_GOOGLE_EMAIL=
E2E_GOOGLE_PASSWORD=

# ---- X / Twitch (stage 1: manual smoke) ----
E2E_X_USERNAME=
E2E_X_PASSWORD=
E2E_TWITCH_USERNAME=
E2E_TWITCH_PASSWORD=
