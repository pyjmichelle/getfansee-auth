# ===========================================
# GetFanSee 环境变量配置
# ===========================================
# 复制此文件为 .env.local 并填写你的配置
# cp .env.example .env.local
# ===========================================

# -------------------------------------------
# Supabase 配置（必需）
# -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service Role Key（仅服务端使用，绝不能暴露给客户端）
# 只在 lib/supabase-admin.ts 中使用
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -------------------------------------------
# PostHog 行为分析与埋点（P0 数据采集）
# -------------------------------------------
# 从 PostHog 项目设置页面获取 API Key
# https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 自托管时修改此 URL，云版本保持默认
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -------------------------------------------
# Sentry 错误监控（P1 可观测性）
# -------------------------------------------
# 从 Sentry Dashboard 获取 DSN
# 格式: https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=

# Sentry 上传 Source Maps（可选）
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# -------------------------------------------
# Didit Webhook（KYC 验证）
# -------------------------------------------
# 从 Didit Dashboard 获取 Webhook Secret
# 用于验证 webhook 请求的签名
DIDIT_WEBHOOK_SECRET=

# -------------------------------------------
# Cron Job 配置
# -------------------------------------------
# 用于验证 Vercel Cron 请求的密钥
# 生成: openssl rand -hex 32
CRON_SECRET=

# -------------------------------------------
# 告警配置
# -------------------------------------------
# Slack Webhook URL（用于金融审计告警）
# 从 Slack App 配置中获取
ALERT_SLACK_WEBHOOK=

# 金融审计阈值
# 交易 pending 超过多少分钟视为卡住
PENDING_STUCK_MINUTES=60
# 一小时内失败交易数超过多少触发告警
FAILED_TXN_THRESHOLD_COUNT=20

# -------------------------------------------
# 测试模式（仅开发/测试环境）
# -------------------------------------------
# 启用测试模式（允许测试账号登录）
# TEST_MODE=true

# 启用 Mock 数据
# USE_MOCK_DATA=true

# Playwright/E2E 测试网关（生产请勿开启）
E2E=1
PLAYWRIGHT_TEST_MODE=true
E2E_ALLOW_ANY_HOST=false

# /api/test/* 额外安全门禁（可选，建议在 CI 设置）
# 调用测试路由时带 header: x-test-secret
TEST_ROUTE_SECRET=

# -------------------------------------------
# 应用配置
# -------------------------------------------
# 基础 URL（用于生成绝对链接）
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 环境标识
NODE_ENV=development

# -------------------------------------------
# Stripe 支付集成
# -------------------------------------------
# 从 https://dashboard.stripe.com/apikeys 获取
STRIPE_SECRET_KEY=sk_test_...
# 从 https://dashboard.stripe.com/webhooks 获取（webhook signing secret）
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe 前端可用的 publishable key（可选，未来用于 Stripe Elements）
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
